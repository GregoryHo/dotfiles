# --- Identity ---

[includeIf "gitdir:~/GitHub/"]
	path = ~/.gitconfig-github

[include]
	path = ~/.gitconfig.local

# --- Core ---

[core]
	autocrlf = input
	excludesfile = ~/.gitignore_global
	editor = vim
	whitespace = tabwidth=4, space-before-tab, indent-with-non-tab, blank-at-eol, blank-at-eof
	pager = delta

[apply]
	whitespace = nowarn

# --- Credentials ---

[credential]
	helper = osxkeychain

[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential

# --- Pager / Delta ---

[delta]
	true-color = always
	theme = Monokai Extended
	plus-style = syntax "#012800"
	minus-style = syntax "#340001"
	plus-emph-style = syntax bold "#012800"
	minus-emph-style = syntax bold "#340001"

[interactive]
	diffFilter = delta --color-only

# --- Color ---

[color]
	branch = auto
	diff = auto
	status = always
	showbranch = auto
	interactive = auto
	ui = true
	pager = true

[color "branch"]
	current = green bold
	local = blue bold
	remote = red bold

[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold

[color "status"]
	added = green bold
	changed = yellow bold
	untracked = red bold

# --- Diff ---

[diff]
	mnemonicPrefix = true
	renames = true
	wordRegex = .
	submodule = log
	tool = vimdiff

[difftool]
	prompt = false

# --- Search ---

[grep]
	break = true
	heading = true
	lineNumber = true
	extendedRegexp = true

# --- Log ---

[log]
	abbrevCommit = true
	follow = true
	decorate = false

# --- Aliases ---

[alias]
	log-all = log --all --decorate --oneline --graph
	log-all-time = log --all --decorate --graph --abbrev-commit --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n'' %C(white)%s%C(reset) %C(dim white)- %an%C(reset)'
