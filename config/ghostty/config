# Ghostty configuration
# Parity target: alacritty.toml (同一套字體 + 配色 + 行為,便於 A/B 切換)

# --- Font ---
font-family = JetBrainsMono Nerd Font Mono
font-style = Medium
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = Bold Italic
font-size = 15
font-thicken = true

# --- Window ---
window-padding-x = 10
window-padding-y = 10
background-opacity = 1.0
macos-titlebar-style = tabs
macos-option-as-alt = true

# --- Cursor ---
cursor-style = block
cursor-style-blink = false

# --- Scrollback (bytes; 字元數 ~20000 行相當於 ~20MB 上限) ---
scrollback-limit = 20000000

# --- Mouse ---
mouse-hide-while-typing = true

# --- Shell integration (Alacritty 沒有的好料) ---
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# --- Primary colors (對應 alacritty colors.primary / cursor / selection) ---
background = 312931
foreground = b9b5b8
cursor-color = b9b5b8
cursor-text = 312931
selection-background = 5a4f5a
selection-foreground = b9b5b8

# --- 16-color palette (0-7 normal, 8-15 bright) ---
palette = 0=#312931
palette = 1=#dd464c
palette = 2=#8fc13e
palette = 3=#fdcc58
palette = 4=#1290bf
palette = 5=#c85e7c
palette = 6=#149b93
palette = 7=#b9b5b8
palette = 8=#797379
palette = 9=#dd464c
palette = 10=#8fc13e
palette = 11=#fdcc58
palette = 12=#1290bf
palette = 13=#c85e7c
palette = 14=#149b93
palette = 15=#ffffff

# --- Quick Terminal (iTerm2 熱鍵式下拉;需 Accessibility 權限) ---
keybind = global:cmd+grave_accent=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-animation-duration = 0.1

# ==============================================================================
# tmux-replacement layer (本機無 tmux 時的功能補齊)
# SSH 遠端仍建議用 tmux;這層只針對本機 Ghostty session。
# ==============================================================================

# --- Session 持久化(tmux-continuum 的降級替代) ---
# 保存 tabs/splits 結構 + cwd,但不保存跑中的 process state。
window-save-state = always

# --- 肌肉記憶:ctrl+a chord prefix(tmux prefix 風格) ---
# 會讓 shell 收不到裸 ctrl+a(readline beginning-of-line)。
# 轉圜:ctrl+a → a 送字面 ctrl+a,等效原 tmux 的 C-a a。
keybind = ctrl+a>a=text:\x01
keybind = ctrl+a>c=new_tab
keybind = ctrl+a>x=close_surface
keybind = ctrl+a>percent=new_split:right
keybind = ctrl+a>quote=new_split:down
keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>j=goto_split:bottom
keybind = ctrl+a>k=goto_split:top
keybind = ctrl+a>l=goto_split:right
keybind = ctrl+a>z=toggle_split_zoom
keybind = ctrl+a>n=next_tab
keybind = ctrl+a>p=previous_tab
keybind = ctrl+a>equal=equalize_splits

# --- OSC 133 prompt jump(需 shell-integration = zsh,上面已開) ---
keybind = cmd+shift+up=jump_to_prompt:-1
keybind = cmd+shift+down=jump_to_prompt:1

# --- 對應原 tmux prefix+L:lazygit 新 tab ---
keybind = cmd+shift+g=new_tab,text:lazygit\n

# --- 對應原 tmux prefix+E:scrollback 丟 $EDITOR(nvim) ---
keybind = cmd+shift+e=write_scrollback_file:open

# --- 對應原 tmux prefix+A/O/G:啟動 Claude/Codex/Gemini ---
keybind = cmd+shift+j=new_tab,text:aa\n
keybind = cmd+shift+k=new_tab,text:ao\n
keybind = cmd+shift+l=new_tab,text:ag\n
