# zoxide (frecency-based cd replacement)
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

# direnv (per-project .envrc auto-load)
if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi

# Homebrew
# Shared fzf UI defaults for shell pickers
dot_fzf_ui() {
  fzf --height=55% --reverse --border --info=inline-right --highlight-line "$@"
}

# Install (one or multiple) selected application(s)
# using "brew search" as source input
# mnemonic [B]rew [I]nstall [P]lugin
bip() {
  dot_require_fzf || return 1
  local selected prog
  selected="$(
    brew search |
      dot_fzf_ui -m --prompt='brew install> ' --header='select package(s)'
  )" || return
  [[ -z "$selected" ]] && return

  while IFS= read -r prog; do
    [[ -n "$prog" ]] && brew install "$prog"
  done <<< "$selected"
}

# Update (one or multiple) selected application(s)
# mnemonic [B]rew [U]pdate [P]lugin
bup() {
  dot_require_fzf || return 1
  local selected prog
  selected="$(
    brew leaves |
      dot_fzf_ui -m --prompt='brew upgrade> ' --header='select package(s)'
  )" || return
  [[ -z "$selected" ]] && return

  while IFS= read -r prog; do
    [[ -n "$prog" ]] && brew upgrade "$prog"
  done <<< "$selected"
}

# Delete (one or multiple) selected application(s)
# mnemonic [B]rew [C]lean [P]lugin (e.g. uninstall)
bcp() {
  dot_require_fzf || return 1
  local selected prog
  selected="$(
    brew leaves |
      dot_fzf_ui -m --prompt='brew uninstall> ' --header='select package(s)'
  )" || return
  [[ -z "$selected" ]] && return

  while IFS= read -r prog; do
    [[ -n "$prog" ]] && brew uninstall "$prog"
  done <<< "$selected"
}

# Install or open the webpage for the selected application
# using brew cask search as input source
# and display a info quickview window for the currently marked application
bci() {
  dot_require_fzf || return 1
  local out key token
  out="$(
    brew search --casks |
      dot_fzf_ui --query="$1" --expect=enter,alt-h \
        --prompt='cask install/home> ' \
        --header='enter=install  alt-h=homepage' \
        --preview 'brew info --cask {}'
  )" || return

  key="$(printf '%s\n' "$out" | sed -n '1p')"
  token="$(printf '%s\n' "$out" | sed -n '2p')"
  [[ -z "$token" ]] && return

  case "$key" in
    alt-h) brew home "$token" ;;
    *) brew install --cask "$token" ;;
  esac
}

# Uninstall or open the webpage for the selected application
# using brew list as input source (all brew cask installed applications)
# and display a info quickview window for the currently marked application
bcui() {
  dot_require_fzf || return 1
  local out key token
  out="$(
    brew list --cask |
      dot_fzf_ui --query="$1" --expect=enter,alt-h \
        --prompt='cask uninstall/home> ' \
        --header='enter=uninstall  alt-h=homepage' \
        --preview 'brew info --cask {}'
  )" || return

  key="$(printf '%s\n' "$out" | sed -n '1p')"
  token="$(printf '%s\n' "$out" | sed -n '2p')"
  [[ -z "$token" ]] && return

  case "$key" in
    alt-h) brew home "$token" ;;
    *) brew uninstall --cask "$token" ;;
  esac
}

# Change directory
# Not including hidden directories
fcd() {
  dot_require_fzf || return 1
  local rows dir
  rows="$(
    find . -mindepth 1 -maxdepth 1 -type d ! -name '.*' -print 2>/dev/null |
      while IFS= read -r d; do
        clean="${d#./}"
        printf '%s\t%-24s %s\n' "$d" "$clean" "$clean"
      done
  )"
  [[ -z "$rows" ]] && return

  dir="$(
    printf '%s\n' "$rows" |
      dot_fzf_ui --prompt='cd> ' --delimiter=$'\t' --with-nth=2 \
        --header='name                     path' |
      cut -f1
  )"
  [[ -n "$dir" ]] && cd "$dir"
}

# Including the hidden directories
fcda() {
  dot_require_fzf || return 1
  local base="${1:-.}" rows dir
  rows="$(
    find "$base" -mindepth 1 -maxdepth 1 -type d -print 2>/dev/null |
      while IFS= read -r d; do
        clean="${d#./}"
        name="${clean##*/}"
        printf '%s\t%-24s %s\n' "$d" "$name" "$clean"
      done
  )"
  [[ -z "$rows" ]] && return

  dir="$(
    printf '%s\n' "$rows" |
      dot_fzf_ui --prompt='cd all> ' --delimiter=$'\t' --with-nth=2 \
        --header='name                     path' |
      cut -f1
  )"
  [[ -n "$dir" ]] && cd "$dir"
}

# Trash commands
rmtrash() {
  mv $@ ~/.Trash/
}

untrash() {
  dot_require_fzf || return 1
  local rows src
  rows="$(
    find "$HOME/.Trash" -mindepth 1 -maxdepth 1 -print 2>/dev/null |
      while IFS= read -r p; do
        name="${p##*/}"
        printf '%s\t%-32s %s\n' "$p" "$name" "$p"
      done
  )"
  [[ -z "$rows" ]] && { echo "Trash is empty."; return 1; }

  src="$(
    printf '%s\n' "$rows" |
      dot_fzf_ui --prompt='untrash> ' --delimiter=$'\t' --with-nth=2 \
        --header='name                              source path' |
      cut -f1
  )"
  [[ -z "$src" ]] && return

  mv -i -- "$src" ./
}

# Git commands
inside_work_tree() { git rev-parse --is-inside-work-tree >/dev/null; }

dot_git_local_branch_rows() {
  git for-each-ref --sort=-committerdate refs/heads \
    --format=$'%(refname:short)\t%(if)%(HEAD)%(then)*%(else) %(end)\t%(upstream:short)\t%(committerdate:relative)' |
    awk -F'\t' '{
      upstream=$3; if (upstream=="") upstream="-";
      printf "%s\t%-2s %-28s %-24s %s\n", $1, $2, $1, upstream, $4
    }'
}

dot_git_remote_branch_rows() {
  git for-each-ref --sort=-committerdate refs/remotes/origin \
    --format=$'%(refname:short)\t%(committerdate:relative)' |
    awk -F'\t' '$1 != "origin/HEAD" {
      short=$1; sub(/^origin\//, "", short);
      printf "%s\t%-30s %s\n", $1, short, $2
    }'
}

# Log all
gla() {
  inside_work_tree || return 1
  dot_require_fzf || return 1

  local filter_file="" selection hash
  if [[ -n "$1" && -f "$1" ]]; then
    filter_file="$1"
  fi

  selection="$(
    (
      export GLA_FILTER_FILE="$filter_file"
      git log --all --decorate --graph --color=always --abbrev=7 \
        --format='%C(bold blue)%h %C(auto)%an %C(bold cyan)%s %C(auto)%d %C(bold yellow)%cr' "$@" |
        dot_fzf_ui --ansi --no-sort --tiebreak=index --prompt='git log> ' \
          --header='enter=open commit  ctrl-y=copy hash' \
          --preview '
            hash=$(printf "%s" "{}" | grep -o "[a-f0-9]\{7\}" | head -1)
            if [[ -n "$hash" ]]; then
              if [[ -n "$GLA_FILTER_FILE" ]]; then
                git show --name-status --color=always "$hash" -- "$GLA_FILTER_FILE"
              else
                git show --name-status --color=always "$hash"
              fi
            fi
          ' \
          --preview-window=right:55% \
          --bind 'ctrl-y:execute-silent(echo {} | grep -o "[a-f0-9]\{7\}" | head -1 | pbcopy)'
    )
  )"
  [[ -z "$selection" ]] && return

  hash="$(printf '%s\n' "$selection" | grep -o '[a-f0-9]\{7\}' | head -1)"
  [[ -z "$hash" ]] && return

  if [[ -n "$filter_file" ]]; then
    git show --color=always "$hash" -- "$filter_file" | less -R
  else
    git show --color=always "$hash" | less -R
  fi
}

# Delete branch
gdb() {
  inside_work_tree || return 1
  dot_require_fzf || return 1

  local rows branch current
  rows="$(dot_git_local_branch_rows)"
  [[ -z "$rows" ]] && return

  branch="$(
    printf '%s\n' "$rows" |
      dot_fzf_ui --prompt='git branch -d> ' --delimiter=$'\t' --with-nth=2 \
        --header='m  branch                        upstream                 last commit' |
      cut -f1
  )" || return
  [[ -z "$branch" ]] && return

  current="$(git branch --show-current)"
  [[ "$branch" == "$current" ]] && { echo "Cannot delete current branch: $branch"; return 1; }
  git branch -d "$branch"
}

# Delete branch with forceed
gdfb() {
  inside_work_tree || return 1
  dot_require_fzf || return 1

  local rows branch current
  rows="$(dot_git_local_branch_rows)"
  [[ -z "$rows" ]] && return

  branch="$(
    printf '%s\n' "$rows" |
      dot_fzf_ui --prompt='git branch -D> ' --delimiter=$'\t' --with-nth=2 \
        --header='m  branch                        upstream                 last commit' |
      cut -f1
  )" || return
  [[ -z "$branch" ]] && return

  current="$(git branch --show-current)"
  [[ "$branch" == "$current" ]] && { echo "Cannot delete current branch: $branch"; return 1; }
  git branch -D "$branch"
}


# Checkout branch
gcob() {
  inside_work_tree || return 1
  dot_require_fzf || return 1

  local rows branch
  rows="$(dot_git_local_branch_rows)"
  [[ -z "$rows" ]] && return

  branch="$(
    printf '%s\n' "$rows" |
      dot_fzf_ui --prompt='git checkout> ' --delimiter=$'\t' --with-nth=2 \
        --header='m  branch                        upstream                 last commit' |
      cut -f1
  )" || return
  [[ -z "$branch" ]] && return

  git checkout "$branch"
}

# Checkout remote branch
gcorb() {
  inside_work_tree || return 1
  dot_require_fzf || return 1

  local rows remote local_branch
  rows="$(dot_git_remote_branch_rows)"
  [[ -z "$rows" ]] && return

  remote="$(
    printf '%s\n' "$rows" |
      dot_fzf_ui --prompt='git checkout remote> ' --delimiter=$'\t' --with-nth=2 \
        --header='remote branch                   last commit' |
      cut -f1
  )" || return
  [[ -z "$remote" ]] && return

  local_branch="${remote#origin/}"
  if git show-ref --verify --quiet "refs/heads/$local_branch"; then
    git checkout "$local_branch"
  else
    git checkout --track "$remote"
  fi
}

# Auto use specify node version via nvmsrc
autoload -U add-zsh-hook

load-nvmrc() {
  local dir="$PWD"
  local nvmrc_path=""

  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/.nvmrc" ]]; then
      nvmrc_path="$dir/.nvmrc"
      break
    fi
    dir="${dir:h}"
  done

  if [ -n "$nvmrc_path" ]; then
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    local nvmrc_node_version
    nvmrc_node_version=$(nvm version "$(cat "${nvmrc_path}")")

    if [ "$nvmrc_node_version" = "N/A" ]; then
      nvm install
    elif [ "$nvmrc_node_version" != "$(nvm version)" ]; then
      nvm use
    fi
  elif typeset -f nvm_find_nvmrc >/dev/null 2>&1; then
    # Only revert if nvm has already been loaded in this shell.
    if [ "$(nvm version)" != "$(nvm version default)" ]; then
      echo "Reverting to nvm default version"
      nvm use default
    fi
  fi
}

add-zsh-hook chpwd load-nvmrc
load-nvmrc

# Git worktree commands
# mnemonic: [W]ork[T]ree [A]dd/[L]ist/[R]emove/[G]o/[P]rune
# Location: sibling directory <repo>-worktrees/ (tool-agnostic)

# Helper: machine rows for worktree pickers.
# columns: 1=path 2=marker(* main) 3=name 4=branch
dot_wt_rows() {
  git worktree list | awk '{
    path=$1
    branch=$3
    gsub(/\[|\]/, "", branch)
    n=split(path, parts, "/")
    name=parts[n]
    marker=(NR==1?"*":" ")
    printf "%s\t%s\t%s\t%s\n", path, marker, name, branch
  }'
}

# Pretty rows: 1=path(key), 2=display
dot_wt_pretty_rows() {
  dot_wt_rows | awk -F'\t' '{printf "%s\t%-2s %-16s %-20s %s\n", $1, $2, $3, $4, $1}'
}

# Helper: resolve sibling worktree directory path
# Returns: /path/to/repo-worktrees
dot_wt_sibling_dir() {
  local root=$(git rev-parse --show-toplevel)
  local base=$(basename "$root")
  local parent=$(dirname "$root")
  echo "${parent}/${base}-worktrees"
}

# List worktrees
alias wtl='git worktree list'

# Add worktree with new branch
# Usage: wta <name> → creates <repo>-worktrees/<name> at feature/<name> branch
wta() {
  local name="$1"
  [[ -z "$name" ]] && { echo "Usage: wta <name>"; return 1; }

  local wt_dir=$(dot_wt_sibling_dir)
  mkdir -p "$wt_dir"
  git worktree add "${wt_dir}/${name}" -b "feature/${name}" && cd "${wt_dir}/${name}"
}

# Add worktree with fzf branch selection
# mnemonic: [W]ork[T]ree [A]dd [B]ranch
wtab() {
  dot_require_fzf || return 1

  local rows branch wt_dir name local_branch
  rows="$(
    {
      git for-each-ref --sort=-committerdate refs/heads \
        --format=$'%(refname:short)\tlocal\t%(committerdate:relative)'
      git for-each-ref --sort=-committerdate refs/remotes/origin \
        --format=$'%(refname:short)\tremote\t%(committerdate:relative)' |
        awk -F'\t' '$1 != "origin/HEAD"'
    } |
      awk -F'\t' '{
        short=$1; sub(/^origin\//, "", short);
        printf "%s\t%-30s %-8s %s\n", $1, short, $2, $3
      }'
  )"
  [[ -z "$rows" ]] && return

  branch="$(
    printf '%s\n' "$rows" |
      dot_fzf_ui --prompt='worktree branch> ' --delimiter=$'\t' --with-nth=2 \
        --header='branch                         source   last commit' |
      cut -f1
  )"
  [[ -z "$branch" ]] && return

  wt_dir=$(dot_wt_sibling_dir)
  name="${branch##*/}"
  mkdir -p "$wt_dir"

  if [[ "$branch" == origin/* ]]; then
    local_branch="${branch#origin/}"
    name="$local_branch"
    if git show-ref --verify --quiet "refs/heads/$local_branch"; then
      git worktree add "${wt_dir}/${name}" "$local_branch" &&
        cd "${wt_dir}/${name}"
    else
      git worktree add "${wt_dir}/${name}" -b "$local_branch" --track "$branch" &&
        cd "${wt_dir}/${name}"
    fi
  else
    git worktree add "${wt_dir}/${name}" "$branch" &&
      cd "${wt_dir}/${name}"
  fi
}

# Remove worktree with fzf selection
# mnemonic: [W]ork[T]ree [R]emove
wtr() {
  dot_require_fzf || return 1

  local rows wt_path
  rows="$(dot_wt_pretty_rows | awk -F'\t' '$2 !~ /^\*/')"
  [[ -z "$rows" ]] && { echo "No removable worktree."; return 1; }

  wt_path="$(
    printf '%s\n' "$rows" |
      dot_fzf_ui --prompt='worktree remove> ' --delimiter=$'\t' --with-nth=2 \
        --header='m  name             branch               path' |
      cut -f1
  )"
  [[ -z "$wt_path" ]] && return

  git worktree remove "$wt_path"
}

# Prune empty worktree sibling directory
# mnemonic: [W]ork[T]ree [P]rune
wtp() {
  local wt_dir=$(dot_wt_sibling_dir)

  if [[ ! -d "$wt_dir" ]]; then
    echo "No worktree directory found: $wt_dir"
    return 0
  fi

  # Check if directory is empty (ignoring .DS_Store and other hidden files)
  local content=$(find "$wt_dir" -mindepth 1 -maxdepth 1 ! -name '.DS_Store' 2>/dev/null)

  if [[ -z "$content" ]]; then
    rm -rf "$wt_dir"
    echo "✓ Removed empty directory: $wt_dir"
  else
    echo "Directory not empty: $wt_dir"
    echo "Contents:"
    ls -la "$wt_dir"
  fi
}

# Go to worktree with fzf selection
# mnemonic: [W]ork[T]ree [G]o
wtg() {
  dot_require_fzf || return 1

  local rows wt_path
  rows="$(dot_wt_pretty_rows)"
  [[ -z "$rows" ]] && return

  wt_path="$(
    printf '%s\n' "$rows" |
      dot_fzf_ui --prompt='worktree go> ' --delimiter=$'\t' --with-nth=2 \
        --header='m  name             branch               path' |
      cut -f1
  )"
  [[ -z "$wt_path" ]] && return

  cd "$wt_path"
}

# Go to main worktree (project root)
# mnemonic: [W]ork[T]ree [B]ase
wtb() {
  cd "$(git worktree list | head -1 | awk '{print $1}')"
}

# Merge worktree branch to main with fzf selection
# mnemonic: [W]ork[T]ree [M]erge
wtm() {
  dot_require_fzf || return 1

  local main_path main_branch rows wt_path wt_branch
  main_path="$(dot_wt_rows | sed -n '1p' | cut -f1)"
  main_branch="$(dot_wt_rows | sed -n '1p' | cut -f4)"

  rows="$(dot_wt_pretty_rows | awk -F'\t' '$2 !~ /^\*/')"
  [[ -z "$rows" ]] && { echo "No worktree branch to merge."; return 1; }

  wt_path="$(
    printf '%s\n' "$rows" |
      dot_fzf_ui --prompt='worktree merge> ' --delimiter=$'\t' --with-nth=2 \
        --header='m  name             branch               path' |
      cut -f1
  )"
  [[ -z "$wt_path" ]] && return

  wt_branch="$(dot_wt_rows | awk -F'\t' -v p="$wt_path" '$1==p{print $4; exit}')"
  [[ -z "$wt_branch" ]] && { echo "Unable to resolve branch for: $wt_path"; return 1; }

  # Go to main worktree and merge
  cd "$main_path" || return 1
  echo "Merging $wt_branch into $main_branch..."

  if git merge "$wt_branch"; then
    echo "✓ Merged successfully"
    echo -n "Remove worktree? [y/N] "
    read -r answer
    [[ "$answer" =~ ^[Yy]$ ]] && git worktree remove "$wt_path" && git branch -d "$wt_branch"
  else
    echo "✗ Merge failed - resolve conflicts manually"
  fi
}

# Add worktree + init environment + start AI agent
# mnemonic: [W]ork[T]ree [C]ode (or Claude/Codex/etc)
wtc() {
  local name="$1"
  local agent="${2:-claude}"  # default agent; can pass claude/codex/gemini/etc.

  wta "$name" || return 1

  # Auto-detect and init environment
  [[ -f "package.json" ]] && {
    [[ -f "pnpm-lock.yaml" ]] && pnpm install
    [[ -f "yarn.lock" ]] && yarn install
    [[ ! -f "pnpm-lock.yaml" && ! -f "yarn.lock" ]] && npm install
  }
  [[ -f "pyproject.toml" || -f "requirements.txt" ]] && {
    command -v uv &>/dev/null && uv sync || {
      [[ -f "requirements.txt" ]] && python -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt
    }
  }

  $agent
}

# Continue most recent agent session
aac() { claude -c "$@"; }
aoc() {
  if [[ "$#" -eq 0 ]]; then
    codex resume --last
  else
    codex resume "$@"
  fi
}
agc() {
  if [[ "$#" -eq 0 ]]; then
    gemini --resume latest
  else
    gemini --resume "$@"
  fi
}

lg() {
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "lg must be run inside a Git repository."
    return 1
  fi
  lazygit "$@"
}

unalias tl tx ts tsw tk tw tsa tda tla tma tat aac aoc agc lg 2>/dev/null

dot_notify_agent() {
  local agent="${1:-agent}" project="${2:-}"
  local name="${project##*/}"
  [[ -z "$name" ]] && name="$agent"
  local task branch msg
  task="$(tmux show-option -wqv -t "$TMUX_PANE" @agent_task 2>/dev/null)"
  branch="$(tmux show-option -wqv -t "$TMUX_PANE" @agent_branch 2>/dev/null)"
  msg="${agent} finished"
  [[ -n "$task" && "$task" != "-" ]] && msg="${msg} '${task}'"
  [[ -n "$branch" && "$branch" != "-" ]] && msg="${msg} on ${branch}"
  msg="${msg} in ${name}"
  osascript -e "display notification \"${msg}\" with title \"Agent Complete\" sound name \"Glass\"" 2>/dev/null
}

dot_agent_window() {
  local agent="$1" cmd="$2" path="$3"
  tmux new-window -n "agent-$agent" -c "$path"
  local branch
  branch="$(cd "$path" && git branch --show-current 2>/dev/null)" || true
  local task="${branch:--}"
  task="${task#feature/}"; task="${task#bugfix/}"; task="${task#hotfix/}"
  task="${task#fix/}"; task="${task#chore/}"; task="${task#release/}"; task="${task#refactor/}"
  tmux set-option -w @project_path "$path" \; \
       set-option -w @agent_type "$agent" \; \
       set-option -w @agent_started_at "$(date +%s)" \; \
       set-option -w @agent_branch "${branch:--}" \; \
       set-option -w @agent_task "$task"
  tmux send-keys "$cmd; dot_notify_agent $agent \"$path\"" C-m
}

tat() {
  if [[ -z "$*" ]]; then
    echo "Usage: tat <task description>"
    return 1
  fi
  tmux set-option -w @agent_task "$*"
}

dot_quick_ask() {
  local agent="$1"

  case "$agent" in
    claude) command -v claude >/dev/null 2>&1 || { echo "claude not found"; return 1; } ;;
    codex)  command -v codex  >/dev/null 2>&1 || { echo "codex not found";  return 1; } ;;
    gemini) command -v gemini >/dev/null 2>&1 || { echo "gemini not found"; return 1; } ;;
    *) echo "Unknown agent: $agent"; return 1 ;;
  esac

  local project="${PWD##*/}"
  local project_hash=$(echo -n "$PWD" | md5 | head -c 8)
  local qa_dir="/tmp/quick-ask-${project}-${project_hash}-${agent}"
  mkdir -p "$qa_dir"

  # Prune Q&A pairs older than 8 hours
  find "$qa_dir" -name "*.q" -mmin +480 2>/dev/null | while read -r f; do
    local id=$(basename "$f" .q)
    rm -f "$qa_dir/$id".{q,a,a.tmp,err,pid}
  done

  # Helper: submit question (agent runs in background, PID tracked for cleanup)
  cat > "$qa_dir/submit.sh" << 'EOF'
#!/bin/zsh
d="$1"; agent="$2"; shift 2
question="$*"
[ -z "$question" ] && exit 0
max_id=$(ls "$d"/*.q 2>/dev/null | sed 's/.*\///;s/\.q$//' | sort -n | tail -1)
n=$(( ${max_id:-0} + 1 ))
printf '%s' "$question" > "$d/$n.q"
# Keep last 20 Q&A pairs
excess=$(( $(ls -1 "$d"/*.q 2>/dev/null | wc -l) - 20 ))
if [ "$excess" -gt 0 ]; then
  ls -t "$d"/*.q | tail -$excess | while read -r f; do
    id=$(basename "$f" .q)
    rm -f "$d/$id".{q,a,a.tmp,err,pid}
  done
fi
(
  _qa_finish() { mv "$d/$n.a.tmp" "$d/$n.a" 2>/dev/null; rm -f "$d/$n.pid"; }
  trap _qa_finish EXIT INT TERM HUP
  case "$agent" in
    claude) claude -p --no-session-persistence "$question" > "$d/$n.a.tmp" 2>"$d/$n.err" ;;
    codex)  codex exec "$question" > "$d/$n.a.tmp" 2>"$d/$n.err" ;;
    gemini) gemini -p "$question" > "$d/$n.a.tmp" 2>"$d/$n.err" ;;
  esac
) &
echo $! > "$d/$n.pid"
EOF
  chmod +x "$qa_dir/submit.sh"

  # Helper: clear all Q&A history and kill running agents
  cat > "$qa_dir/clear.sh" << 'EOF'
#!/bin/zsh
d="$1"
for p in "$d"/*.pid(N); do kill "$(cat "$p")" 2>/dev/null; done
rm -f "$d"/*.q "$d"/*.a "$d"/*.a.tmp "$d"/*.err "$d"/*.pid 2>/dev/null
EOF
  chmod +x "$qa_dir/clear.sh"

  # Helper: list Q&A history rows
  cat > "$qa_dir/list.sh" << 'EOF'
#!/bin/zsh
d="$1"
for f in $(ls -rt "$d"/*.q 2>/dev/null); do
  id=$(basename "$f" .q)
  q=$(cat "$f")
  if [ -f "$d/$id.a" ]; then
    printf '%s\t  ✓ %s\n' "$id" "$q"
  else
    printf '%s\t  ⏳ %s\n' "$id" "$q"
  fi
done
EOF
  chmod +x "$qa_dir/list.sh"

  # Helper: preview response for selected item
  cat > "$qa_dir/preview.sh" << 'EOF'
#!/bin/zsh
d="$1"; id="$2"
if [ -z "$id" ]; then
  printf '\033[90mType a question above and press Enter\033[0m'
elif [ -f "$d/$id.a" ]; then
  cat "$d/$id.a"
elif [ -f "$d/$id.pid" ]; then
  printf '\033[90m⏳ thinking...\033[0m'
elif [ -f "$d/$id.err" ]; then
  printf '\033[31m✗ Error:\033[0m\n'
  cat "$d/$id.err"
else
  printf '\033[90m⏳ thinking...\033[0m'
fi
EOF
  chmod +x "$qa_dir/preview.sh"

  # Skip refresh-preview for completed items to avoid resetting the user's scroll position
  local reload_action="reload-sync($qa_dir/list.sh $qa_dir)"
  cat > "$qa_dir/poll.sh" << EOF
#!/bin/zsh
was_pending=0
while sleep 2; do
  [ -d "$qa_dir" ] || break
  # Promote responses from dead agent processes (SIGKILL fallback — normal exits use the trap)
  for p in "$qa_dir"/*.pid(N); do
    kill -0 "\$(cat "\$p")" 2>/dev/null && continue
    id=\${p:t:r}
    [ -f "$qa_dir/\$id.a.tmp" ] && mv "$qa_dir/\$id.a.tmp" "$qa_dir/\$id.a" 2>/dev/null
    rm -f "\$p"
  done
  pid_files=("$qa_dir"/*.pid(N))
  pending=\${#pid_files}
  if [ "\$pending" -gt 0 ]; then
    curl -sXPOST "http://127.0.0.1:\$1" -d "transform([ -f $qa_dir/{1}.pid ] && echo '$reload_action+refresh-preview' || echo '$reload_action')" 2>/dev/null || break
  elif [ "\$was_pending" -gt 0 ]; then
    curl -sXPOST "http://127.0.0.1:\$1" -d "$reload_action+refresh-preview" 2>/dev/null || break
  fi
  was_pending=\$pending
done
EOF
  chmod +x "$qa_dir/poll.sh"

  # Cleanup: kill running agents but preserve history dir
  dot_quick_ask_cleanup() {
    for pidfile in "$qa_dir"/*.pid; do
      [ -f "$pidfile" ] || continue
      kill "$(cat "$pidfile")" 2>/dev/null
    done
  }
  trap dot_quick_ask_cleanup EXIT INT TERM

  local list_cmd="$qa_dir/list.sh $qa_dir"
  local submit_cmd="$qa_dir/submit.sh $qa_dir $agent"
  local preview_cmd="$qa_dir/preview.sh $qa_dir {1}"

  local title
  title=$(printf '\033[1;35m%s\033[0m quick-ask in \033[1m%s\033[0m' "$agent" "$project")

  local copy_cmd="[ -f '$qa_dir'/{1}.a ] && pbcopy < '$qa_dir'/{1}.a"
  local clear_cmd="$qa_dir/clear.sh $qa_dir"

  true | fzf --ansi \
    --height=100% \
    --disabled \
    --prompt='> ' \
    --border-label=" $title " \
    --border-label-pos=top \
    --preview="$preview_cmd" \
    --preview-window='down:70%:wrap' \
    --preview-label=' Response ' \
    --delimiter=$'\t' --with-nth=2 \
    --no-info --no-sort \
    --header='  ctrl-y=copy  ctrl-x=clear  esc=quit' \
    --bind "enter:execute-silent($submit_cmd {q})+clear-query+reload-sync($list_cmd)" \
    --bind "ctrl-y:execute-silent($copy_cmd)+bell" \
    --bind "ctrl-x:execute-silent($clear_cmd)+reload-sync($list_cmd)+refresh-preview" \
    --listen 127.0.0.1:0 \
    --bind "start:reload-sync($list_cmd)+execute-silent($qa_dir/poll.sh \$FZF_PORT &)" \
    --bind 'esc:abort'
}

dot_require_fzf() {
  if ! command -v fzf >/dev/null 2>&1; then
    echo "fzf not found in PATH"
    return 1
  fi
}

dot_tmux_cmd() {
  command tmux "$@"
}

dot_tmux_session_rows() {
  local current=""
  if [[ -n "$TMUX" ]]; then
    current="$(dot_tmux_cmd display-message -p '#S' 2>/dev/null)"
  fi

  dot_tmux_cmd list-sessions -F $'#{session_name}\t#{session_attached}\t#{session_windows}' 2>/dev/null |
    while IFS=$'\t' read -r name attached windows; do
      local marker="o"
      local state="idle"
      [[ "$attached" -gt 0 ]] && { marker="+"; state="attached"; }
      [[ -n "$current" && "$name" == "$current" ]] && { marker="*"; state="current"; }
      # Machine-readable columns:
      # 1=session_name 2=marker 3=state 4=attached_count 5=window_count
      printf '%s\t%s\t%s\t%s\t%s\n' "$name" "$marker" "$state" "$attached" "$windows"
    done
}

dot_tmux_session_pretty_rows() {
  dot_tmux_session_rows |
    awk -F'\t' '{
      session=$1
      if (length(session) > 20) session=substr(session, 1, 17) "..."
      printf "%s\t%-2s %-9s %-20s %7s %7s\n", $1, $2, $3, session, $4, $5
    }'
}

dot_tmux_pane_pretty_rows() {
  dot_tmux_cmd list-panes -a -F $'#{session_name}:#{window_index}.#{pane_index}\t#{window_name}\t#{pane_current_command}\t#{pane_current_path}' |
    awk -F'\t' '{
      cwd=$4
      window=$2
      cmd=$3
      if (length(window) > 14) window=substr(window, 1, 11) "..."
      if (length(cmd) > 10) cmd=substr(cmd, 1, 7) "..."
      if (length(cwd) > 50) cwd="..." substr(cwd, length(cwd)-46)
      printf "%s\t%-12s %-14s %-10s %s\n", $1, $1, window, cmd, cwd
    }'
}

dot_tmux_window_pretty_rows() {
  dot_tmux_cmd list-windows -a -F $'#{session_name}:#{window_index}\t#{session_name}\t#{window_index}\t#{window_name}\t#{window_panes}\t#{window_active}' 2>/dev/null |
    awk -F'\t' '{
      mark=($6=="1"?"*":" ")
      name=$4
      if (length(name) > 16) name=substr(name, 1, 13) "..."
      printf "%s\t%-2s %-14s %3s %-16s %5s\n", $1, mark, $2, $3, name, $5
    }'
}

dot_agent_pane_rows() {
  local now
  now="$(date +%s)"

  dot_tmux_cmd list-panes -a \
    -F $'#{session_name}:#{window_index}.#{pane_index}\t#{window_name}\t#{pane_current_command}\t#{@project_path}\t#{pane_current_path}\t#{window_activity}\t#{@agent_type}\t#{@agent_branch}\t#{@agent_task}\t#{@agent_started_at}' 2>/dev/null |
    awk -F'\t' -v now="$now" -v home="$HOME" -v user_shell="$(basename "$SHELL")" '
    function fmttime(s) {
      if (s < 60)        return s "s"
      if (s < 3600)      return int(s/60) "m"
      if (s < 86400)     return int(s/3600) "h"
      return int(s/86400) "d"
    }
    {
      target=$1; wname=$2; cmd=$3; projpath=$4; cwd=$5; activity=$6
      atype=$7; abranch=$8; atask=$9; astarted=$10

      agent=""
      if (atype != "") agent = atype
      if (agent == "") {
        if (wname ~ /^agent-claude/)      agent="claude"
        else if (wname ~ /^agent-codex/)  agent="codex"
        else if (wname ~ /^agent-gemini/) agent="gemini"
      }
      if (agent == "") {
        if (cmd ~ /^claude/)  agent="claude"
        else if (cmd ~ /^codex/)   agent="codex"
        else if (cmd ~ /^gemini/)  agent="gemini"
      }
      if (agent == "") next

      alive = (cmd != user_shell) ? 1 : 0

      split(target, t, ":")
      session = t[1]

      p = (projpath != "" ? projpath : cwd)
      n = split(p, parts, "/")
      project = (n > 0 ? parts[n] : p)
      if (length(project) > 20) project = substr(project, 1, 17) "..."

      branch = (abranch != "" ? abranch : "-")
      task = (atask != "" ? atask : "-")
      if (length(branch) > 20) branch = substr(branch, 1, 17) "..."
      if (length(task) > 16) task = substr(task, 1, 13) "..."

      idle = (activity != "" && activity > 0) ? now - activity : 0
      if (!alive)            status = "exited"
      else if (idle < 10)    status = "active"
      else if (idle < 300)   status = "busy"
      else                   status = "idle"

      idlefmt = fmttime(idle)
      durfmt = (astarted != "" && astarted+0 > 0) ? fmttime(now - astarted) : "-"

      cwd_short = cwd
      if (home != "" && substr(cwd_short, 1, length(home)) == home)
        cwd_short = "~" substr(cwd_short, length(home) + 1)
      if (length(cwd_short) > 40) cwd_short = "..." substr(cwd_short, length(cwd_short) - 36)

      printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n", target, agent, session, project, branch, task, status, idlefmt, durfmt, cwd_short
    }'
}

dot_agent_pane_format_rows() {
  local mode="${1:-full}"
  local c_claude=$'\033[35m' c_codex=$'\033[32m' c_gemini=$'\033[34m'
  local c_active=$'\033[32m' c_busy=$'\033[33m' c_idle=$'\033[90m' c_exited=$'\033[31m'
  local c_reset=$'\033[0m'

  dot_agent_pane_rows |
    while IFS=$'\t' read -r target agent session project branch task astate idle duration cwd; do
      local c_agent="" icon="" c_st=""
      case "$agent" in
        claude) c_agent="$c_claude" ;;
        codex)  c_agent="$c_codex" ;;
        gemini) c_agent="$c_gemini" ;;
      esac
      case "$astate" in
        active) c_st="$c_active" icon="●" ;;
        busy)   c_st="$c_busy"   icon="◉" ;;
        idle)   c_st="$c_idle"   icon="○" ;;
        exited) c_st="$c_exited" icon="✕" ;;
      esac
      if [[ "$mode" == "compact" ]]; then
        printf '%s\t%s%s%s %s%-7s%s %-20s %-16s %s%-7s%s\n' \
          "$target" "$c_st" "$icon" "$c_reset" \
          "$c_agent" "$agent" "$c_reset" "$project" "$task" \
          "$c_st" "$astate" "$c_reset"
      elif [[ "$astate" == "exited" ]]; then
        printf '%s\t%s%s%s %s%-7s %-12s %-20s %-20s %-16s %-7s %5s %5s  %s%s\n' \
          "$target" "$c_exited" "$icon" "$c_reset" \
          "$c_idle" "$agent" "$session" "$project" "$branch" "$task" \
          "$astate" "$idle" "$duration" "$cwd" "$c_reset"
      else
        printf '%s\t%s%s%s %s%-7s%s %-12s %-20s %-20s %-16s %s%-7s%s %5s %5s  %s\n' \
          "$target" "$c_st" "$icon" "$c_reset" \
          "$c_agent" "$agent" "$c_reset" "$session" "$project" "$branch" "$task" \
          "$c_st" "$astate" "$c_reset" "$idle" "$duration" "$cwd"
      fi
    done
}
dot_agent_pane_pretty_rows() { dot_agent_pane_format_rows full; }
dot_agent_pane_picker_rows() { dot_agent_pane_format_rows compact; }

# tmux session control plane (works inside and outside tmux)
tl() {
  local rows
  rows="$(dot_tmux_session_pretty_rows)"
  if [[ -z "$rows" ]]; then
    echo "No tmux sessions. Use: tx <name>"
    return 1
  fi
  printf '%-2s %-9s %-20s %7s %7s\n' "m" "state" "session" "clients" "wins"
  printf '%s\n' "$rows" | awk -F'\t' '{print $2}'
}

tx() {
  local name="${1:-$(basename "$PWD")}"
  if [[ -n "$TMUX" ]]; then
    if dot_tmux_cmd has-session -t "$name" 2>/dev/null; then
      dot_tmux_cmd switch-client -t "$name"
    else
      dot_tmux_cmd new-session -d -s "$name" -c "$PWD"
      dot_tmux_cmd switch-client -t "$name"
    fi
  else
    dot_tmux_cmd new-session -A -s "$name" -c "$PWD"
  fi
}

ts() {
  dot_require_fzf || return 1

  local rows target
  rows="$(dot_tmux_session_pretty_rows)"
  if [[ -z "$rows" ]]; then
    echo "No tmux sessions. Use: tx <name>"
    return 1
  fi

  target="$(
    printf '%s\n' "$rows" |
      dot_fzf_ui --prompt='session> ' --delimiter=$'\t' --with-nth=2 \
        --header=$'m  state     session               clients   wins' |
      cut -f1
  )"
  [[ -z "$target" ]] && return

  if [[ -n "$TMUX" ]]; then
    dot_tmux_cmd switch-client -t "$target"
  else
    dot_tmux_cmd attach-session -t "$target"
  fi
}

tk() {
  local target="$1"
  if [[ -z "$target" ]]; then
    dot_require_fzf || return 1
    local rows selected
    rows="$(dot_tmux_session_pretty_rows)"
    if [[ -z "$rows" ]]; then
      echo "No tmux sessions to kill."
      return 1
    fi
    selected="$(
      printf '%s\n' "$rows" |
        dot_fzf_ui --prompt='kill session> ' --delimiter=$'\t' --with-nth=2 \
          --header=$'m  state     session               clients   wins'
    )"
    target="$(printf '%s' "$selected" | cut -f1)"
  fi

  [[ -z "$target" ]] && return
  dot_tmux_cmd kill-session -t "$target"
}

tsw() {
  dot_require_fzf || return 1

  local rows target session
  rows="$(dot_tmux_window_pretty_rows)"
  if [[ -z "$rows" ]]; then
    echo "No tmux windows. Use: tx <name>"
    return 1
  fi

  target="$(
    printf '%s\n' "$rows" |
      dot_fzf_ui --prompt='window> ' --delimiter=$'\t' --with-nth=2 \
        --header=$'m  session         idx window            panes' |
      cut -f1
  )"
  [[ -z "$target" ]] && return

  session="${target%%:*}"
  if [[ -n "$TMUX" ]]; then
    dot_tmux_cmd switch-client -t "$session"
    dot_tmux_cmd select-window -t "$target"
  else
    dot_tmux_cmd attach-session -t "$target"
  fi
}

dot_tmux_window_exists() {
  local session="$1"
  local window="$2"
  dot_tmux_cmd list-windows -t "$session" -F '#W' 2>/dev/null | grep -Fxq "$window"
}

dot_tmux_window_pane_count() {
  local target="$1"
  dot_tmux_cmd list-panes -t "$target" 2>/dev/null | wc -l | tr -d ' '
}

dot_tmux_bootstrap_window_layout() {
  local session="$1"
  local root="$2"
  local panes

  panes="$(dot_tmux_window_pane_count "${session}:editor")"
  if [[ "$panes" -eq 1 ]]; then
    dot_tmux_cmd split-window -d -h -p 30 -t "${session}:editor" -c "$root"
  fi

  panes="$(dot_tmux_window_pane_count "${session}:test")"
  if [[ "$panes" -eq 1 ]]; then
    dot_tmux_cmd split-window -d -v -p 35 -t "${session}:test" -c "$root"
  fi
}

dot_detect_watch_cmd() {
  local root="$1"
  local pkg="$root/package.json"
  local runner=""
  local cmd=""

  if [[ -n "${TW_WATCH_CMD:-}" ]]; then
    printf '%s' "$TW_WATCH_CMD"
    return 0
  fi

  if [[ -f "$root/.tw-watch" ]]; then
    cmd="$(sed -n '1p' "$root/.tw-watch" | tr -d '\r')"
    if [[ -n "$cmd" ]]; then
      printf '%s' "$cmd"
      return 0
    fi
  fi

  if [[ -f "$pkg" ]]; then
    if [[ -f "$root/pnpm-lock.yaml" ]] && command -v pnpm >/dev/null 2>&1; then
      runner="pnpm"
    elif [[ -f "$root/yarn.lock" ]] && command -v yarn >/dev/null 2>&1; then
      runner="yarn"
    elif command -v npm >/dev/null 2>&1; then
      runner="npm"
    fi

    if [[ -n "$runner" ]]; then
      if rg -q '"test:watch"\\s*:' "$pkg"; then
        if [[ "$runner" == "npm" ]]; then
          printf '%s' "npm run test:watch"
        else
          printf '%s' "$runner run test:watch"
        fi
        return 0
      fi

      if rg -q '"test"\\s*:' "$pkg"; then
        if [[ "$runner" == "npm" ]]; then
          printf '%s' "npm test -- --watch"
        else
          printf '%s' "$runner test -- --watch"
        fi
        return 0
      fi
    fi
  fi

  if command -v pytest >/dev/null 2>&1; then
    if [[ -f "$root/pytest.ini" || -f "$root/pyproject.toml" || -d "$root/tests" ]]; then
      printf '%s' "pytest -f"
      return 0
    fi
  fi

  return 1
}

dot_tmux_start_watch_if_needed() {
  local session="$1"
  local root="$2"
  local should_bootstrap="$3"
  local watch_target="${session}:test.1"
  local watch_cmd=""

  [[ "${TW_AUTO_WATCH:-1}" == "0" ]] && return 0
  [[ "$should_bootstrap" -eq 1 ]] || return 0

  watch_cmd="$(dot_detect_watch_cmd "$root" || true)"
  if [[ -n "$watch_cmd" ]]; then
    dot_tmux_cmd send-keys -t "$watch_target" "$watch_cmd" C-m
  else
    dot_tmux_cmd send-keys -t "$watch_target" "echo '[tw] No watch command detected. Set TW_WATCH_CMD or add .tw-watch'" C-m
  fi
}

# tw: expand default workspace windows in target session.
# default windows: editor, agent-claude, test, logs
# pane roles:
# - editor: code + shell
# - test: watch + adhoc
tw() {
  local name root editor_pane panes
  local created_session=0
  local created_test_window=0
  local should_bootstrap_watch=0
  if [[ -n "$1" ]]; then
    name="$1"
  elif [[ -n "$TMUX" ]]; then
    name="$(dot_tmux_cmd display-message -p '#S')"
  else
    name="$(basename "$PWD")"
  fi
  root="${2:-$PWD}"

  if ! dot_tmux_cmd has-session -t "$name" 2>/dev/null; then
    editor_pane="$(dot_tmux_cmd new-session -d -P -F '#{pane_id}' -s "$name" -n editor -c "$root")" || return 1
    dot_tmux_cmd send-keys -t "$editor_pane" "nvim ." C-m
    created_session=1
  elif ! dot_tmux_window_exists "$name" "editor"; then
    editor_pane="$(dot_tmux_cmd new-window -d -P -F '#{pane_id}' -t "$name" -n editor -c "$root")" || return 1
    dot_tmux_cmd send-keys -t "$editor_pane" "nvim ." C-m
  fi

  dot_tmux_window_exists "$name" "agent-claude" || dot_tmux_cmd new-window -d -t "$name" -n agent-claude -c "$root"
  if ! dot_tmux_window_exists "$name" "test"; then
    dot_tmux_cmd new-window -d -t "$name" -n test -c "$root" || return 1
    created_test_window=1
  fi
  dot_tmux_window_exists "$name" "logs" || dot_tmux_cmd new-window -d -t "$name" -n logs -c "$root"

  dot_tmux_bootstrap_window_layout "$name" "$root"

  panes="$(dot_tmux_window_pane_count "${name}:editor")"
  if [[ "$panes" -ge 1 ]]; then
    dot_tmux_cmd select-pane -t "${name}:editor.1" -T code 2>/dev/null
  fi
  if [[ "$panes" -ge 2 ]]; then
    dot_tmux_cmd select-pane -t "${name}:editor.2" -T shell 2>/dev/null
  fi

  panes="$(dot_tmux_window_pane_count "${name}:agent-claude")"
  if [[ "$panes" -ge 1 ]]; then
    dot_tmux_cmd select-pane -t "${name}:agent-claude.1" -T agent-claude 2>/dev/null
  fi

  panes="$(dot_tmux_window_pane_count "${name}:test")"
  if [[ "$panes" -ge 1 ]]; then
    dot_tmux_cmd select-pane -t "${name}:test.1" -T watch 2>/dev/null
  fi
  if [[ "$panes" -ge 2 ]]; then
    dot_tmux_cmd select-pane -t "${name}:test.2" -T adhoc 2>/dev/null
  fi

  panes="$(dot_tmux_window_pane_count "${name}:logs")"
  if [[ "$panes" -ge 1 ]]; then
    dot_tmux_cmd select-pane -t "${name}:logs.1" -T logs 2>/dev/null
  fi

  if [[ "$created_session" -eq 1 || "$created_test_window" -eq 1 ]]; then
    should_bootstrap_watch=1
  fi
  dot_tmux_start_watch_if_needed "$name" "$root" "$should_bootstrap_watch"

  if [[ -n "$TMUX" ]]; then
    dot_tmux_cmd switch-client -t "$name"
  else
    dot_tmux_cmd attach-session -t "$name"
  fi

  dot_tmux_cmd select-window -t "$name:editor" 2>/dev/null
}

dot_tmux_goto_pane() {
  local target="$1"
  local session="${target%%:*}"
  local pane="${target##*.}"
  local window="${target#*:}"
  window="${window%.*}"

  if [[ -n "$TMUX" ]]; then
    dot_tmux_cmd switch-client -t "$session"
    dot_tmux_cmd select-window -t "${session}:${window}"
    dot_tmux_cmd select-pane -t "${session}:${window}.${pane}"
  else
    dot_tmux_cmd attach-session -t "$session" \; select-window -t "${session}:${window}" \; select-pane -t "${session}:${window}.${pane}"
  fi
}

tsp() {
  dot_require_fzf || return 1
  local target
  target="$(
    dot_tmux_pane_pretty_rows |
      dot_fzf_ui --delimiter=$'\t' --with-nth=2 --prompt='pane> ' \
        --header=$'target       window          cmd        cwd' |
      cut -f1
  )"
  [[ -z "$target" ]] && return
  dot_tmux_goto_pane "$target"
}

tsa() {
  dot_require_fzf || return 1

  local rows target
  local reload_cmd='source ~/.zshrc.local 2>/dev/null; dot_agent_pane_picker_rows'
  rows="$(dot_agent_pane_picker_rows)"
  if [[ -z "$rows" ]]; then
    echo "No active agents. Launch with prefix+A/O/G."
    read -sk1 '?Press any key to close...'
    return 0
  fi

  local col_hdr
  col_hdr="$(printf '  %-7s %-20s %-16s %s' type project task status)"

  target="$(
    printf '%s\n' "$rows" |
      dot_fzf_ui --height=100% --ansi --prompt='agent> ' --delimiter=$'\t' --with-nth=2 --accept-nth=1 \
        --header="$col_hdr" \
        --bind "ctrl-r:reload-sync($reload_cmd)" \
        --bind 'esc:abort'
  )"
  [[ -z "$target" ]] && return
  dot_tmux_goto_pane "$target"
}

tda() {
  dot_require_fzf || return 1

  local rows target
  local reload_cmd='source ~/.zshrc.local 2>/dev/null; dot_agent_pane_pretty_rows'
  rows="$(dot_agent_pane_pretty_rows)"
  if [[ -z "$rows" ]]; then
    echo "No active agents. Launch with prefix+A/O/G."
    read -sk1 '?Press any key to close...'
    return 0
  fi

  local col_hdr
  col_hdr="$(printf '  %-7s %-12s %-20s %-20s %-16s %-7s %5s %5s  %s' type session project branch task status idle dur cwd)"

  local fzf_enter
  fzf_enter='enter:transform:if [[ {fzf:prompt} =~ send ]]; then if [[ -n {q} ]]; then echo "execute-silent(tmux send-keys -t {1} -l {q}; tmux send-keys -t {1} Enter)+clear-query+enable-search+change-prompt(agent> )+reload-sync(___RELOAD___)"; else echo "clear-query+enable-search+change-prompt(agent> )"; fi; else echo accept; fi'
  fzf_enter="${fzf_enter//___RELOAD___/$reload_cmd}"

  target="$(
    printf '%s\n' "$rows" |
      dot_fzf_ui --height=100% --ansi --prompt='agent> ' --delimiter=$'\t' --with-nth=2 --accept-nth=1 \
        --border-label=' ctrl-r=refresh  alt-s=send  ctrl-x=stop  alt-k=kill ' \
        --header="$col_hdr" \
        --preview='tmux capture-pane -t {1} -ep -S -200 2>/dev/null | sed "s/\x1b\[[?]*[0-9;]*[A-Za-ln-z]//g" || echo "No preview"' \
        --preview-window=down:70%:wrap:follow \
        --preview-label=' Agent Preview ' \
        --listen 127.0.0.1:0 \
        --bind "start:execute-silent(while sleep 2; do curl -sXPOST http://127.0.0.1:\$FZF_PORT -d refresh-preview 2>/dev/null || break; done &)" \
        --bind 'ctrl-/:change-preview-window(down:80%:wrap:follow|down:70%:wrap:follow|hidden)' \
        --bind "ctrl-r:reload-sync($reload_cmd)" \
        --bind "ctrl-x:execute-silent(tmux send-keys -t {1} C-c)+reload-sync($reload_cmd)" \
        --bind "alt-k:execute-silent(tmux kill-pane -t {1})+reload-sync($reload_cmd)" \
        --bind 'alt-s:disable-search+clear-query+change-prompt(send> )' \
        --bind "$fzf_enter" \
        --bind 'esc:transform:[[ {fzf:prompt} =~ send ]] && echo "clear-query+enable-search+change-prompt(agent> )" || echo abort'
  )"
  [[ -z "$target" ]] && return
  dot_tmux_goto_pane "$target"
}

tma() {
  dot_require_fzf || return 1

  local reload_cmd='source ~/.zshrc.local 2>/dev/null; dot_agent_pane_pretty_rows'
  local reload_action="reload-sync(${reload_cmd})+refresh-preview"

  local col_hdr
  col_hdr="$(printf '  %-7s %-12s %-20s %-20s %-16s %-7s %5s %5s  %s' type session project branch task status idle dur cwd)"

  local fzf_enter
  fzf_enter='enter:transform:if [[ {fzf:prompt} =~ send ]]; then if [[ -n {q} ]]; then echo "execute-silent(tmux send-keys -t {1} -l {q}; tmux send-keys -t {1} Enter)+clear-query+enable-search+change-prompt(monitor> )+reload-sync(___RELOAD___)"; else echo "clear-query+enable-search+change-prompt(monitor> )"; fi; fi'
  fzf_enter="${fzf_enter//___RELOAD___/$reload_cmd}"

  dot_agent_pane_pretty_rows |
    dot_fzf_ui --height=100% --ansi \
      --prompt='monitor> ' --delimiter=$'\t' --with-nth=2 \
      --border-label=' Agent Monitor — ctrl-r=refresh  alt-s=send  ctrl-x=stop  alt-k=kill ' \
      --header="$col_hdr" \
      --preview='tmux capture-pane -t {1} -ep -S -200 2>/dev/null | sed "s/\x1b\[[?]*[0-9;]*[A-Za-ln-z]//g" || echo "No preview"' \
      --preview-window=down:70%:wrap:follow \
      --preview-label=' Agent Preview ' \
      --listen 127.0.0.1:0 \
      --bind "start:execute-silent{while sleep 5; do curl -sXPOST http://127.0.0.1:\$FZF_PORT --data-raw '${reload_action}' 2>/dev/null || break; done &}" \
      --bind 'ctrl-/:change-preview-window(down:80%:wrap:follow|down:70%:wrap:follow|hidden)' \
      --bind "ctrl-r:reload-sync($reload_cmd)+refresh-preview" \
      --bind "ctrl-x:execute-silent(tmux send-keys -t {1} C-c)+reload-sync($reload_cmd)" \
      --bind "alt-k:execute-silent(tmux kill-pane -t {1})+reload-sync($reload_cmd)" \
      --bind 'alt-s:disable-search+clear-query+change-prompt(send> )' \
      --bind "$fzf_enter" \
      --bind 'esc:transform:[[ {fzf:prompt} =~ send ]] && echo "clear-query+enable-search+change-prompt(monitor> )" || echo abort'
}

tla() {
  local rows
  rows="$(dot_agent_pane_rows)"
  if [[ -z "$rows" ]]; then
    echo "No active agents. Launch with prefix+A/O/G."
    return 0
  fi

  printf '%-7s %-12s %-20s %-20s %-16s %-7s %5s %5s  %s\n' "type" "session" "project" "branch" "task" "status" "idle" "dur" "cwd"
  printf '%s\n' "$rows" |
    awk -F'\t' '{
      printf "%-7s %-12s %-20s %-20s %-16s %-7s %5s %5s  %s\n", $2, $3, $4, $5, $6, $7, $8, $9, $10
    }'
}
