# Aliases
alias vim='nvim'
alias vi='nvim'
alias mvim='nvim'
export EDITOR='nvim'
export VISUAL='nvim'
export GIT_EDITOR='nvim'
alias rm='echo "Foce add option -i. (**Warning** addtional -f will override this)";rm -i'
# alias python=~/.pyenv/versions/2.7.18/bin/python  # Commented for ARM migration

